{
  "name": "opencode-chatroom-voice",
  "version": "0.1.0",
  "description": "OpenCode plugin: event-driven voice integration via a Phoenix-channel voice backend (browser TTS/STT, multi-room, multimedia replies).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rostchri/opencode-plugins.git",
    "directory": "chatroom-voice"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm",
    "build:tsc": "tsc --outDir dist --declaration --declarationMap",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/index.test.mjs"
  },
  "dependencies": {
    "phoenix": "1.8.7"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@opencode-ai/sdk": "latest",
    "typescript": "5.8.2"
  }
}
